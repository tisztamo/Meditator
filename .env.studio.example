# Copy this file to `.env.studio` and edit the values.
#
# STUDIO_TOKEN is the shared password used by the Studio login form.
# STUDIO_SESSION_SECRET must be a long random string used to sign the
# httpOnly session cookie. Keep both values out of git.

STUDIO_TOKEN=change-me
STUDIO_SESSION_SECRET=change-me-too

# OPENAI_API_KEY turns on the Studio's Voice Mode (talk to a mind and hear it
# speak) and real <m-image> generation. Without it, Voice Mode stays hidden.
# Optional voice knobs (defaults shown) — see doc/studio.md#voice-mode.
#OPENAI_API_KEY=sk-...
#STUDIO_VOICE_NAME=marin
#STUDIO_TTS_MODEL=gpt-4o-mini-tts
#STUDIO_STT_MODEL=gpt-4o-transcribe
#STUDIO_VOICE=0          # set to 0 to switch Voice Mode off even with a key
